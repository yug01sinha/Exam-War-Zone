{
  "name": "exam-war-room-landing",
  "version": "0.1.0",
  "private": true,
  "description": "Landing page for Exam War Room — AI study companion for CBSE Class 10 students with Supabase authentication",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "opennextjs-cloudflare build",
