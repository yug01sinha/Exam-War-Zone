@import "tailwindcss";

:root {
  --background: #ffffff;
  --foreground: #171717;
  /* Design System Colors from reference */
  --ink: #12131a;
  --muted: #5b5f70;
  --faint: #9395a8;
  --tint: #f6f6fd;
  --tint2: #eeeefb;
  --border: #e7e7f2;
  --indigo: #5b4bf5;
  --violet: #8b5cf6;
  --blue: #4f8cf7;
  --green: #1fb571;
  --gold: #e0a527;
  --red: #e0524f;
  --grad: linear-gradient(120deg, var(--indigo), var(--violet) 55%, var(--blue));
  --shadow: 0 20px 50px -20px rgba(37,32,89,0.28);
  --shadow-sm: 0 8px 22px -12px rgba(37,32,89,0.18);
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --font-sans: var(--font-geist-sand);
  --font-mono: var(--font-geist-mono);

  /* Custom fonts */
  --font-space-grotesk: 'Space Grotesk', sans-serif;
  --font-inter: 'Inter', sans-serif;
  --font-jetbrains-mono: 'JetBrains Mono', monospace;
}

@media (prefers-color-scheme: dark) {
  :root {
    --background: #0a0a0a;
    --foreground: #ededest;
  }
}

body {
  background: var(--background);
  color: var(--foreground);
  font-family: var(--font-inter);
  font-smooth: always;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* Custom animations */
@keyframes wave {
  0%, 100% { transform: rotate(0); }
  15% { transform: rotate(14deg); }
  30% { transform: rotate(-8deg); }
  45% { transform: rotate(14deg); }
  60% { transform: rotate(0); }
}

@keyframes fadeup {
  to { opacity: 1; transform: translateY(0); }
}

@keyframes bootPulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.12); opacity: .8; }
}

/* Utility classes for animations */
.animate-wave {
  display: inline-block;
  animation: wave 2.4s ease-in-out infinite;
  transform-origin: 70% 70%;
}

.animate-fadeup {
  opacity: 0;
  transform: translateY(14px);
  animation: fadeup 0.5s ease forwards;
}

/* Staggered animation delays */
.delay-2 { animation-delay: 0.02s; }
.delay-8 { animation-delay: 0.08s; }
.delay-14 { animation-delay: 0.14s; }
.delay-20 { animation-delay: 0.2s; }

/* Boot overlay */
.boot-overlay {
  position: fixed;
  inset: 0;
  z-index: 1000;
  background: radial-gradient(circle at 50% 45%, #1c1a33 0%, #0d0c18 75%);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.6s ease, visibility 0.6s ease;
}

.boot-overlay.hide {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

.boot-mark {
  width: 74px;
  height: 74px;
  border-radius: 20px;
  background: var(--grad);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 60px rgba(139,92,246,.5);
  animation: bootPulse 1.1s ease-in-out infinite;
}

.boot-mark svg {
  width: 36px;
  height: 36px;
}

.boot-label {
  position: absolute;
  margin-top: 130px;
  font-family: var(--font-jetbrains-mono);
  font-size: 12px;
  letter-spacing: 0.12em;
  color: rgba(255,255,255,.45);
  text-transform: uppercase;
}

/* Element transitions for boot sequence */
.sidebar-boot {
  opacity: 0;
  transform: translateX(-24px);
  transition: opacity 0.6s cubic-bezier(.16,.8,.3,1), transform 0.6s cubic-bezier(.16,.8,.3,1);
}

.sidebar-boot.in {
  opacity: 1;
  transform: translateX(0);
}

.topbar-boot {
  opacity: 0;
  transform: translateY(-10px);
  transition: opacity 0.5s ease, transform 0.5s ease;
}

.topbar-boot.in {
  opacity: 1;
  transform: translateY(0);
}

.boot-target {
  opacity: 0;
  transform: translateY(20px) scale(.98);
  transition: opacity 0.55s cubic-bezier(.16,.8,.3,1), transform 0.55s cubic-bezier(.16,.8,.3,1);
}

.boot-target.in {
  opacity: 1;
  transform: translateY(0) scale(1);
}

/* Replay button */
.replay-btn {
  width: 42px;
  height: 42px;
  border-radius: 12px;
  background: #fff;
  border: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  flex-shrink: 0;
  transition: transform 0.2s ease;
}

.replay-btn:hover {
  transform: rotate(-45deg);
}

.replay-btn svg {
  width: 16px;
  height: 16px;
  color: var(--muted);
}

/* Prefers-reduced-motion overrides */
@media (prefers-reduced-motion: reduce) {
  * {
    animation-duration: 0.001ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.001ms !important;
  }

  .sidebar-boot, .topbar-boot, .boot-target {
    opacity: 1 !important;
    transform: none !important;
  }

  .boot-overlay {
    display: none !important;
  }
}

/* Custom utility classes for design system */
.bg-tint { background-color: var(--tint); }
.bg-tint2 { background-color: var(--tint2); }
.bg-border { background-color: var(--border); }
.text-ink { color: var(--ink); }
.text-muted { color: var(--muted); }
 utilities {
  .text-faint { color: #9395a8; }
}
 utilities {\n  .text-faint { color: #9395a8; }\n}\n
/* Gradient utilities */
.from-indigo { from: var(--indigo); }
.via-violet { via: var(--violet); }
.to-blue { to: var(--blue); }
.from-violet { from: var(--violet); }
.to-indigo { to: var(--indigo); }
.from-blue { from: var(--blue); }
.to-indigo-900 { to: var(--indigo); }

/* Text font families */
.font-space-grotesk { font-family: var(--font-space-grotesk); }
.font-inter { font-family: var(--font-inter); }
.font-jetbrains-mono { font-family: var(--font-jetbrains-mono); }

/* Gradient text */
.bg-clip-text { background-clip: text; }
.text-transparent { color: transparent; }

/* Specific component styles */
.nav-item {
  @apply flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 hover:bg-white/10 hover:text-white;
}

.nav-item.active {
  @apply bg-[var(--grad)] text-white shadow-[var(--shadow-sm)];
}

.nav-item .badge-count {
  @apply ml-auto font-jetbrains-mono text-xs font-semibold bg-white/18 text-white px-2.5 py-0.5 rounded-full;
}

.nav-item.active .badge-count {
  @apply bg-white/28;
}

.logout {
  @apply flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 hover:bg-white/10 hover:text-white;
}

.topbar {
  @apply flex items-center justify-between gap-5;
}

.greet h1 {
  @apply text-xl font-bold flex items-center gap-2;
}
.greet .sub {
@apply    text-xs text-faint mt-1;
}

.search {
@apply    flex-1 max-w-xs items-center gap-2.5 px-4 py-2.5 bg-white border border-border rounded-lg text-faint;
}

.bell {
  @apply w-10 h-10 items-center justify-center bg-white border border-border rounded-lg relative cursor-pointer flex-shrink-0;
}

.bell .dot {
  @apply absolute top-[9px] right-[10px] w-[7px] h-[7px] rounded-full bg-red border-2 border-white;
}

.panel {
  @apply bg-white rounded-lg border border-border p-5.5;
}

.panel-head {
  @apply flex items-center justify-between mb-4.5;
}

.panel-head h2 {
  @apply text-lg font-bold;
}

.link {
  @apply text-xs font-bold text-indigo cursor-pointer;
}

.subj-card {
  @apply rounded-xl overflow-hidden border border-border opacity-0 transform translate-y-[14px];
}

.subj-card.active-animation {
  @apply animate-fadeup;
}

.subj-thumb {
  @apply h-[118px] relative flex items-center justify-center overflow-hidden;
}

.subj-thumb .emoji {
  @apply text-5xl relative z-2 drop-shadow-[0_6px_14px_rgba(0,0,0,0.15)];
}

.subj-thumb::before {
  @content "''";
  @absolute inset-0;
  @opacity 0.9;
}

.thumb-math::before {
  @background linear-gradient(135deg, var(--indigo), #8b7cff);
}

.thumb-sci::before {
  @background linear-gradient(135deg, var(--green), #8be0b8);
}

.thumb-soc::before {
  @background linear-gradient(135deg, #e0724f, #f5c26b);
}

.thumb-eng::before {
  @background linear-gradient(135deg, var(--blue), #8bd0ff);
}

.subj-body {
  @apply p-4;
}

.subj-body h3 {
  @apply text-lg font-bold mb-3;
}

.track {
  @apply h-1.5 bg-tint rounded-full overflow-hidden mb-2;
}

.fill {
  @apply h-full bg-[var(--grad)] rounded-full transition-all duration-1100 ease-[cubic-bezier(0.16,0.8,0.3,1)] w-0;
}

.subj-meta {
  @apply flex justify-between text-xs text-faint font-semibold mt-2 mb-3;
}

.subj-meta .pct {
  @apply font-jetbrains-mono text-ink;
}

.btn-continue {
  @apply w-full px-3 py-2.5 rounded-lg bg-ink text-white text-sm font-semibold transition-transform duration-180 hover:-translate-y-[2px];
}

.reminder-grid {
  @apply grid grid-cols-3 gap-3.5;
}

.rem-card {
  @apply rounded-lg p-4 flex flex-col gap-2.5 min-h-[150px];
}

.rem-card.c1 {
  @apply bg-[#fdf4de];
}

.rem-card.c1 .btn-mini {
  @apply bg-ink text-white;
}

.rem-card.c2 {
  @apply bg-tint2;
}

.rem-card.c3 {
  @apply bg-[#fdeeea];
}

.rem-title {
  @apply text-sm font-bold;
}

.rem-due {
  @apply text-xs text-muted;
}

.btn-mini {
  @apply mt-auto px-3 py-2 rounded-lg bg-ink text-white text-xs font-semibold flex items-center gap-1.5 self-start;
}

.legend {
  @apply flex gap-4 mt-1 text-xs text-muted font-semibold;
}

.legend span {
  @apply flex items-center gap-1.5;
}

.legend .d {
  @apply w-[7px] h-[7px] rounded-full;
}

.d.learn {
  @apply bg-indigo;
}

.d.test {
  @apply bg-[#e0724f];
}

.d.revise {
  @apply bg-[var(--gold)];
}

.toggle-group {
  @apply flex bg-tint rounded-lg p-0.5 gap-0.5;
}

.toggle-btn {
  @apply px-3.5 py-2 text-xs font-semibold bg-transparent rounded hover:text-white/80;
}

.toggle-btn.active {
  @apply bg-ink text-white;
}

.chart-wrap {
  @apply h-[220px] flex items-end gap-3.5 pt-2.5 relative;
}

.chart-grid {
  @apply absolute inset-x-0 bottom-[30px] flex flex-col justify-between;
}

.gline {
  @apply border-t-[1px] border-dashed border-border relative;
}

.gline span {
  @apply absolute left-[-28px] top-[-7px] text-xs text-muted font-jetbrains-mono;
}

.bar-col {
  @apply flex-1 flex flex-col items-center justify-end gap-2 relative z-2;
}

.bar {
  @apply w-[60%] rounded-tl-[8px] rounded-tr-[8px] rounded-br-[4px] rounded-bl-[4px] bg-gradient-to-t from-violet to-indigo h-0 transition-all duration-1000 ease-[cubic-bezier(0.16,0.8,0.3,1)] relative;
}

.bar.today {
  @apply bg-gradient-to-t from-blue to-indigo;
}

.day-label {
  @apply text-xs text-muted font-semibold mt-0.5;
}

.bar-col.active .day-label {
  @apply text-ink font-bold;
}

.bar-dot {
  @apply w-[7px] h-[7px] rounded-full bg-ink absolute top-[-11px] left-1/2 -translate-x-1/2;
}

.tc-row {
  @apply flex items-center gap-3 py-3;
}

.tc-row + .tc-row {
  @apply border-t border-border;
}

.tc-thumb {
  @apply w-[44px] h-[44px] rounded-lg flex-shrink-0 flex items-center justify-center text-xl;
}

.tc-body {
  @apply flex-1 min-w-0;
}

.tc-title {
  @apply text-sm font-bold;
}

.tc-tag {
  @apply inline-block text-xs font-bold px-2 py-0.5 rounded;
}

.tc-tag.beg {
  @apply bg-[#eaf7f0] text-green;
}

.tc-tag.int {
  @apply bg-[#fdeeea] text-[#c8543e];
}

.tc-tag.adv {
  @apply bg-tint2 text-indigo;
}

.tc-stats {
  @apply flex items-center gap-3.5 text-xs text-muted font-semibold flex-shrink-0;
}

.tc-stats span {
  @apply flex items-center gap-1;
}

.tc-stats svg {
  @apply w-[13px] h-[13px];
}

.profile-panel {
  @apply relative rounded-xl p-6 overflow-hidden text-white bg-gradient-to-t from-[#6a5bf7] via-[#8b5cf6] to-[#4f8cf7];
}

.profile-panel::before {
  @content "''";
  @absolute inset-x-0 -top-[90px] -right-[70px];
  @size 220px;
  @rounded-full;
  @bg-white/12;
}

.profile-top {
  @apply flex items-center gap-3.5 mb-5 relative;
}

.p-avatar {
  @apply w-[54px] h-[54px] rounded-[14px] bg-white/20 border border-white/30 flex items-center justify-center font-bold text-xl shrink-0;
}

.profile-top .p-name {
  @apply text-lg font-bold;
}

.profile-top .p-handle {
  @apply text-xs opacity-75;
}

.pill-row {
  @apply flex gap-2 mb-5.5 relative;
}

.stat-pill {
  @apply flex-1 bg-white/16 rounded-[13px] px-2.5 py-2.5 text-center;
}

.stat-pill b {
  @apply block font-jetbrains-mono text-2xl;
}

.stat-pill span {
  @apply text-xs opacity-8 font-semibold;
}

.cal-card {
  @apply bg-white/14 rounded-lg p-4 relative;
}

.cal-top {
  @apply flex items-center justify-between mb-3 font-bold text-sm;
}

.cal-arrow {
  @apply w-[22px] h-[22px] rounded-sm bg-white/15 flex items-center justify-center cursor-pointer shrink-0;
}

.cal-arrow svg {
  @apply w-[12px] h-[12px];
}

.cal-days {
  @apply grid grid-cols-7 gap-1 text-center mb-1.5;
}

.cal-day {
  @apply text-xs opacity-65 font-semibold mb-1.5;
}

.cal-date {
  @apply w-[28px] h-[28px] flex items-center justify-center text-sm font-bold rounded relative;
}

.cal-date.today {
  @apply bg-white text-indigo;
}

.cal-date .dd {
  @absolute bottom-[2px] left-1/2 -translate-x-1/2;
  @size [3px];
  @rounded-full;
  @bg-white;
}

.events-title {
  @apply font-bold text-sm mt-5 mb-3 relative;
}

.event-card {
  @apply bg-white/14 rounded-lg p-3.5 mb-2.5 relative;
}

.event-top {
  @apply flex justify-between items-center mb-2;
}

.event-tag {
  @apply text-xs font-bold bg-white/22 px-2 py-0.5 rounded-[7px];
}

.event-time {
  @apply text-xs font-bold bg-white text-ink px-2 py-0.5 rounded-[7px];
}

.event-desc {
  @apply text-xs leading-1.4 opacity-92;
}

.btn-viewall {
  @apply w-full mt-1.5 px-3 py-2.5 rounded-lg bg-white text-ink font-bold text-sm cursor-pointer relative;
}

